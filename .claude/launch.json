{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "SwimBuddy Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "8081"],
      "port": 8081,
      "cwd": "app"
    },
    {
      "name": "Prototype",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8090"],
      "port": 8090,
      "cwd": "prototype-preview"
    },
    {
      "name": "SwimBuddy API",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["wrangler", "dev", "--port", "8787"],
      "port": 8787,
      "cwd": "api"
    }
  ]
}
