{
  "name": "swimbuddy-api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate": "wrangler d1 migrations apply swimbuddy-db",
    "migrate:local": "wrangler d1 migrations apply swimbuddy-db --local",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "moduleDirectories": ["node_modules", "../node_modules"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "tsconfig": {
          "module": "CommonJS",
          "moduleResolution": "node"
        }
      }]
    }
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "drizzle-kit": "^0.31.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "wrangler": "^4.90.1"
  }
}
